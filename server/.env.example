# Google AI Studio / Gemini API key used by the image generation endpoint.
# Required for POST /api/generate-image. Obtain one at https://aistudio.google.com/.
NANO_BANANA_API_KEY=

# HTTP port the Express server binds to. Defaults to 3001.
PORT=3001

# Override the directory where persisted generations (metadata + image files)
# are written. Defaults to `./generations` relative to the server's cwd.
# ADFORGE_GENERATIONS_DIR=/var/lib/adforge/generations
